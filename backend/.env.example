# Hermes / LLM gateway (comment -> structured review JSON)
HERMES_API_KEY=
HERMES_GATEWAY_URL=http://localhost:PORT/gateway
OPENAI_API_KEY=

# Convex (used by backend to write results back, if backend talks to Convex directly)
CONVEX_URL=https://original-rooster-551.convex.cloud
CONVEX_DEPLOY_KEY=

# Dodo Payments (company subscription checkout — $49/mo, 7-day trial)
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_SECRET=
DODO_SUBSCRIPTION_PRODUCT_ID=
DODO_ENVIRONMENT=test_mode

# Must match the Convex env var of the same name (npx convex env set
# WEBHOOK_SHARED_SECRET ...) — lets the backend call internal Convex actions
# after verifying a Dodo webhook signature.
WEBHOOK_SHARED_SECRET=

# App
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
